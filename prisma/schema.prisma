generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Relationship {
  id        String   @id @default(cuid())
  fromEns   String
  toEns     String
  createdAt DateTime @default(now())

  @@unique([fromEns, toEns])
}
